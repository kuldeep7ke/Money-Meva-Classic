# Google OAuth with Supabase (optional)
# 1. Create a project at https://supabase.com
# 2. Go to Authentication → Providers → Google → Enable
# 3. Set up Google Cloud OAuth credentials (redirect to https://your-domain/auth/callback)
# 4. Copy your project URL and anon key below
# 5. Rename this file to .env.local and fill in the values
#
# Without these set, the app runs in local-only mode (email/password in localStorage).
# Google Sign-In button will attempt OAuth but will fail without real credentials.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
